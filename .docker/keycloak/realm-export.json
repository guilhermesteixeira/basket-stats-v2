{
  "realm": "basket-stats",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "clients": [
    {
      "clientId": "basket-stats-api",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:5273/*", "http://localhost:5173/*", "http://localhost:4173/*"],
      "webOrigins": ["http://localhost:5273", "http://localhost:5173", "http://localhost:4173"],
      "protocolMappers": [
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "basket-stats-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "admin", "description": "Administrator" },
      { "name": "match-creator", "description": "Can create and manage matches" },
      { "name": "viewer", "description": "Read-only access" }
    ]
  },
  "users": [
    {
      "username": "admin@basketstats.com",
      "email": "admin@basketstats.com",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "match-creator"]
    },
    {
      "username": "creator@basketstats.com",
      "email": "creator@basketstats.com",
      "firstName": "Match",
      "lastName": "Creator",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "creator123",
          "temporary": false
        }
      ],
      "realmRoles": ["match-creator"]
    },
    {
      "username": "viewer@basketstats.com",
      "email": "viewer@basketstats.com",
      "firstName": "Viewer",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "viewer123",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
