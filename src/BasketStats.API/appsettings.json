{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Url": "http://localhost:8080",
    "Realm": "master",
    "ClientId": "basket-stats",
    "ClientSecret": "${KEYCLOAK_CLIENT_SECRET}"
  },
  "Firestore": {
    "ProjectId": "basket-stats-dev",
    "EmulatorHost": "localhost:8081"
  },
  "CloudStorage": {
    "BucketName": "basket-stats-dev",
    "EmulatorEndpoint": "http://localhost:4443"
  },
  "Jwt": {
    "Audience": "basket-stats",
    "ClaimsMapping": {
      "NameClaimType": "name",
      "RoleClaimType": "roles"
    }
  }
}
